{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "kairo-status-hub",
          "appId": "1:498359023979:android:dd000d8ccad0638ae3342e",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "kairo-status-hub",
          "appId": "1:498359023979:ios:eca8836e8c07547ae3342e",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "kairo-status-hub",
          "configurations": {
            "android": "1:498359023979:android:dd000d8ccad0638ae3342e",
            "ios": "1:498359023979:ios:eca8836e8c07547ae3342e",
            "web": "1:498359023979:web:7c1ebf3012b8533ee3342e"
          }
        }
      }
    }
  }
}
